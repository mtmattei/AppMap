<UserControl x:Class="Atlas.App.Presentation.Controls.NodeCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Atlas.App.Presentation"
             xmlns:utu="using:Uno.Toolkit.UI"
             Width="182">

  <UserControl.Resources>
    <local:NodeKindToBrushConverter x:Key="KindToAccent"
                                    Shell="{ThemeResource AtlasShellBrush}"
                                    Page="{ThemeResource AtlasDeclaredBrush}"
                                    Dialog="{ThemeResource AtlasLiveBrush}" />
    <local:UpperConverter x:Key="Upper" />
    <local:StatusVisibleConverter x:Key="StatusVisible" />
  </UserControl.Resources>

  <!-- Top padding leaves room for the live/orphan tags overlapping the card edge -->
  <Grid>
    <utu:CardContentControl Margin="0,9,0,0"
                            MinHeight="78"
                            Style="{StaticResource FilledCardContentControlStyle}"
                            Background="{ThemeResource AtlasSurfaceBrush}"
                            BorderBrush="{ThemeResource AtlasBorder2Brush}"
                            BorderThickness="1"
                            CornerRadius="9"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            AutomationProperties.Name="{Binding Name}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Kind accent: left bar, color by NodeKind -->
        <Border Width="3"
                Background="{Binding Kind, Converter={StaticResource KindToAccent}}"
                CornerRadius="2,0,0,2" />

        <utu:AutoLayout Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="2"
                        Padding="11,9,11,10">
          <TextBlock Text="{Binding Kind, Converter={StaticResource Upper}}"
                     Style="{StaticResource AtlasMonoCaption}" />
          <TextBlock Text="{Binding Name}"
                     Style="{StaticResource AtlasMonoStrong}" />
          <TextBlock Style="{StaticResource AtlasMonoRoute}"
                     Opacity="0.85"
                     TextTrimming="CharacterEllipsis">
            <Run Text="/" /><Run Text="{Binding Route}" />
          </TextBlock>
          <TextBlock Text="{Binding ViewModel}"
                     Style="{StaticResource AtlasMonoType}" />
        </utu:AutoLayout>
      </Grid>
    </utu:CardContentControl>

    <Border HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,0,10,0"
            CornerRadius="5"
            Padding="7,2"
            Background="{ThemeResource AtlasLiveBrush}"
            Visibility="{Binding Status, Converter={StaticResource StatusVisible}, ConverterParameter=Live}">
      <TextBlock Text="LIVE"
                 Style="{StaticResource AtlasMonoCaption}"
                 Foreground="{ThemeResource OnPrimaryBrush}" />
    </Border>

    <Border HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="10,0,0,0"
            CornerRadius="5"
            Padding="7,2"
            Background="{ThemeResource AtlasOrphanBrush}"
            Visibility="{Binding Status, Converter={StaticResource StatusVisible}, ConverterParameter=Orphan}">
      <TextBlock Text="ORPHAN"
                 Style="{StaticResource AtlasMonoCaption}"
                 Foreground="{ThemeResource OnErrorBrush}" />
    </Border>
  </Grid>
</UserControl>
