<Page x:Class="Atlas.App.Presentation.MapPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Atlas.App.Presentation"
      xmlns:controls="using:Atlas.App.Presentation.Controls"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      NavigationCacheMode="Required"
      KeyboardAcceleratorPlacementMode="Hidden"
      Background="{StaticResource AtlasCanvasBrush}">

  <Page.Resources>
    <local:UpperConverter x:Key="Upper" />
    <local:StatusVisibleConverter x:Key="StatusVisible" />
    <local:NodeJsonConverter x:Key="NodeJson" />
    <local:IndexVisibleConverter x:Key="IndexVisible" />
    <local:StringVisibleConverter x:Key="StringVisible" />
    <local:NotNullVisibleConverter x:Key="NotNullVisible" />
    <local:BoolToBrushConverter x:Key="ConnectedDot"
                                TrueBrush="{StaticResource AtlasObservedBrush}"
                                FalseBrush="{StaticResource AtlasTextMuted2Brush}" />
  </Page.Resources>

  <!-- Canvas shortcuts, mirroring Hot Design: Ctrl+0 reset, Ctrl+9 fit, Ctrl+/- zoom -->
  <Page.KeyboardAccelerators>
    <KeyboardAccelerator Modifiers="Control"
                         Key="Number0"
                         Invoked="ResetView_Invoked" />
    <KeyboardAccelerator Modifiers="Control"
                         Key="Number9"
                         Invoked="FitView_Invoked" />
    <KeyboardAccelerator Modifiers="Control"
                         Key="Add"
                         Invoked="ZoomInKey_Invoked" />
    <KeyboardAccelerator Modifiers="Control"
                         Key="Subtract"
                         Invoked="ZoomOutKey_Invoked" />
  </Page.KeyboardAccelerators>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <utu:AutoLayout Orientation="Horizontal"
                    Justify="SpaceBetween"
                    CounterAxisAlignment="Center"
                    Spacing="18"
                    Padding="18,10"
                    Background="{StaticResource AtlasPanelBrush}"
                    BorderBrush="{StaticResource AtlasBorderBrush}"
                    BorderThickness="0,0,0,1">

      <utu:AutoLayout Orientation="Horizontal"
                      Spacing="10"
                      CounterAxisAlignment="Center">
        <!-- Sized wrapper: the 45° rotation otherwise overflows the layout slot -->
        <Grid Width="22"
              Height="22">
          <Border Width="14"
                  Height="14"
                  CornerRadius="3"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <RotateTransform Angle="45" />
            </Border.RenderTransform>
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource AtlasUnreachableColor}" Offset="0" />
                <GradientStop Color="{StaticResource AtlasDeclaredColor}" Offset="0.33" />
                <GradientStop Color="{StaticResource AtlasObservedColor}" Offset="0.66" />
                <GradientStop Color="{StaticResource AtlasShellColor}" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </Grid>
        <TextBlock Text="ATLAS"
                   Style="{StaticResource AtlasMonoTitle}"
                   CharacterSpacing="140" />
        <TextBlock Text="AGENTIC APP MAP"
                   Style="{StaticResource AtlasMonoCaption}" />
      </utu:AutoLayout>

      <utu:AutoLayout Orientation="Horizontal"
                      Spacing="8"
                      CounterAxisAlignment="Center">
        <Button Content="Open model…"
                Style="{StaticResource TextButtonStyle}"
                Command="{Binding OpenModel}"
                AutomationProperties.Name="Open an app model file" />
        <Button Content="Extract from source…"
                Style="{StaticResource TextButtonStyle}"
                Command="{Binding ExtractFromSource}"
                AutomationProperties.Name="Extract a model from app source" />
        <Border CornerRadius="24"
                Padding="11,5"
                BorderBrush="{StaticResource AtlasBorderBrush}"
                BorderThickness="1">
          <TextBlock x:Name="AppNamePill"
                     Text="{Binding Graph.App, Converter={StaticResource Upper}}"
                     Style="{StaticResource AtlasMonoCaption}"
                     Foreground="{StaticResource AtlasTextBrush}" />
        </Border>
        <Button x:Name="RecentButton"
                Content="▾"
                Padding="6,2"
                Style="{StaticResource TextButtonStyle}"
                AutomationProperties.Name="Open a recent model">
          <Button.Flyout>
            <MenuFlyout x:Name="RecentFlyout"
                        Opening="RecentFlyout_Opening" />
          </Button.Flyout>
        </Button>
        <Border CornerRadius="24"
                Padding="11,5"
                BorderBrush="{StaticResource AtlasBorderBrush}"
                BorderThickness="1">
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="7"
                          CounterAxisAlignment="Center">
            <Ellipse Width="7"
                     Height="7"
                     Fill="{Binding RuntimeConnected, Converter={StaticResource ConnectedDot}}" />
            <TextBlock Text="{Binding RuntimeLabel}"
                       Style="{StaticResource AtlasMonoCaption}" />
          </utu:AutoLayout>
        </Border>
      </utu:AutoLayout>
    </utu:AutoLayout>

    <!-- Content: canvas + docked panel. The panel is a fixed column on wide form factors
         (SPEC); DrawerControl is reserved for narrow widths — while open it covers the
         main content with a hit-test-visible light-dismiss overlay that blocks the canvas. -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="372" />
      </Grid.ColumnDefinitions>

      <Grid x:Name="CanvasHost"
            Background="{StaticResource AtlasCanvasBrush}"
            AllowDrop="True"
            DragOver="CanvasHost_DragOver"
            Drop="CanvasHost_Drop"
            DragLeave="CanvasHost_DragLeave"
            PointerPressed="CanvasHost_PointerPressed"
            PointerMoved="CanvasHost_PointerMoved"
            PointerReleased="CanvasHost_PointerReleased"
            PointerCaptureLost="CanvasHost_PointerCaptureLost">
          <utu:ZoomContentControl x:Name="MapZoom"
                                  MinZoomLevel="0.25"
                                  MaxZoomLevel="3.0"
                                  IsZoomAllowed="True"
                                  IsPanAllowed="True"
                                  AutoFitToCanvas="True"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
            <mvux:FeedView Source="{Binding Graph}">
              <mvux:FeedView.ValueTemplate>
                <DataTemplate>
                  <Canvas Width="1700"
                          Height="660">
                    <!-- Content-space dot lattice: pans/scales with the graph for depth -->
                    <controls:DotGrid Width="1700"
                                      Height="660"
                                      Spacing="32"
                                      DotRadius="1.2"
                                      Opacity="0.55"
                                      Fill="{StaticResource AtlasBorder2Brush}" />
                    <!-- StaticResource: ThemeResource does not apply to custom DPs inside templates -->
                    <controls:EdgeLayer Source="{Binding Data}"
                                        ObservedBrush="{StaticResource AtlasObservedBrush}"
                                        DeclaredBrush="{StaticResource AtlasDeclaredBrush}"
                                        UnreachableBrush="{StaticResource AtlasUnreachableBrush}"
                                        ShowObserved="{Binding DataContext.ShowObserved, ElementName=Root, Mode=OneWay}"
                                        ShowDeclared="{Binding DataContext.ShowDeclared, ElementName=Root, Mode=OneWay}"
                                        ShowUnreachable="{Binding DataContext.ShowUnreachable, ElementName=Root, Mode=OneWay}"
                                        HighlightedNodeIds="{Binding DataContext.AgentResult.NodeIds, ElementName=Root, Mode=OneWay}"
                                        HighlightedEdgeKeys="{Binding DataContext.AgentResult.EdgeKeys, ElementName=Root, Mode=OneWay}" />
                    <!-- Parent = the page VM exposed by FeedView's template state -->
                    <ItemsRepeater ItemsSource="{Binding Data.Nodes}"
                                   utu:CommandExtensions.Command="{Binding Parent.SelectNode}">
                      <ItemsRepeater.Layout>
                        <local:CanvasLayout />
                      </ItemsRepeater.Layout>
                      <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <controls:NodeCard SelectedId="{Binding DataContext.Selected.Id, ElementName=Root, Mode=OneWay}"
                                             HighlightedIds="{Binding DataContext.AgentResult.NodeIds, ElementName=Root, Mode=OneWay}"
                                             MoveCommand="{Binding DataContext.MoveNode, ElementName=Root, Mode=OneWay}"
                                             DragDelta="NodeCard_DragDelta"
                                             Tapped="NodeCard_Tapped"
                                             DoubleTapped="NodeCard_DoubleTapped" />
                        </DataTemplate>
                      </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                  </Canvas>
                </DataTemplate>
              </mvux:FeedView.ValueTemplate>
            </mvux:FeedView>
          </utu:ZoomContentControl>

          <!-- Legend: provenance layer toggles (line style + color per kind) -->
          <Border HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="14"
                  Background="{StaticResource AtlasPanelBrush}"
                  BorderBrush="{StaticResource AtlasBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="9"
                  Padding="13,11">
            <utu:AutoLayout Orientation="Vertical"
                            Spacing="4">
              <CheckBox IsChecked="{Binding ShowObserved, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle observed edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasObservedBrush}"
                        StrokeThickness="2" />
                  <TextBlock Text="Observed"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="RUNTIME"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <CheckBox IsChecked="{Binding ShowDeclared, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle declared edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasDeclaredBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="3,3" />
                  <TextBlock Text="Declared"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="ROUTE MAP"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <CheckBox IsChecked="{Binding ShowUnreachable, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle unreachable edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasUnreachableBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="1,3" />
                  <TextBlock Text="Unreachable"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="DEAD"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <TextBlock Text="TOGGLE LAYERS"
                         Style="{StaticResource AtlasMonoCaption}" />
              <TextBlock Text="CTRL+WHEEL ZOOM · MIDDLE-DRAG PAN"
                         Style="{StaticResource AtlasMonoCaption}" />
            </utu:AutoLayout>
          </Border>

          <!-- View controls -->
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="7"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,14,14">
            <Button x:Name="ZoomOutButton"
                    Content="−"
                    Click="ZoomOut_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Zoom out" />
            <Button x:Name="ZoomInButton"
                    Content="+"
                    Click="ZoomIn_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Zoom in" />
            <Button x:Name="ZoomFitButton"
                    Content="⊡"
                    Click="ZoomFit_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Fit map to view" />
          </utu:AutoLayout>

          <!-- Transient notice: confirms Jump / Scope / Open model without stealing input.
               Starts hidden; Reveal.When fades it with the bound value. -->
          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Bottom"
                  Margin="0,0,0,20"
                  Background="{StaticResource AtlasSurface2Brush}"
                  BorderBrush="{StaticResource AtlasBorder2Brush}"
                  BorderThickness="1"
                  CornerRadius="999"
                  Padding="16,8"
                  IsHitTestVisible="False"
                  Opacity="0"
                  Visibility="Collapsed"
                  local:Reveal.When="{Binding Notice}">
            <TextBlock Text="{Binding Notice}"
                       Style="{StaticResource AtlasMonoBody}" />
          </Border>

          <!-- Drop affordance: dashed outline + prompt while a file is dragged over the canvas.
               Hit-test-invisible so the drop reaches CanvasHost; toggled from code-behind. -->
          <Grid x:Name="DropOverlay"
                Visibility="Collapsed"
                Opacity="0"
                IsHitTestVisible="False">
            <Rectangle Margin="16"
                       RadiusX="12"
                       RadiusY="12"
                       Stroke="{StaticResource AtlasDeclaredBrush}"
                       StrokeThickness="2"
                       StrokeDashArray="6,4"
                       Fill="{StaticResource AtlasPanelBrush}"
                       Opacity="0.85" />
            <TextBlock Text="Drop an app-model .json"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Style="{StaticResource AtlasMonoBody}" />
          </Grid>
      </Grid>

      <!-- Docked panel -->
      <Grid Grid.Column="1"
            Background="{StaticResource AtlasPanelBrush}"
            BorderBrush="{StaticResource AtlasBorderBrush}"
            BorderThickness="1,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>

          <utu:TabBar x:Name="PanelTabs"
                      SelectedIndex="{Binding PanelTab, Mode=TwoWay}"
                      Style="{StaticResource TopTabBarStyle}">
            <utu:TabBarItem Content="AGENT"
                            AutomationProperties.Name="Agent panel" />
            <utu:TabBarItem Content="INSPECTOR"
                            AutomationProperties.Name="Inspector panel" />
          </utu:TabBar>

          <!-- Agent pane -->
          <ScrollViewer Grid.Row="1"
                        Visibility="{Binding SelectedIndex, ElementName=PanelTabs, Converter={StaticResource IndexVisible}, ConverterParameter=0}">
            <utu:AutoLayout Orientation="Vertical"
                            Spacing="16"
                            Padding="16,18">
              <TextBlock Text="{Binding AgentIntro}"
                         Style="{StaticResource AtlasUiProse}"
                         Foreground="{StaticResource AtlasTextMutedBrush}" />

              <!-- Free-text question: routed through the local QuestionInterpreter over the graph. -->
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Question, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="Ask about a screen, orphans, duplicates…"
                         utu:CommandExtensions.Command="{Binding AskQuestion}"
                         AutomationProperties.Name="Ask the agent a question" />
                <Button Grid.Column="1"
                        Content="Ask"
                        Style="{StaticResource FilledButtonStyle}"
                        Command="{Binding AskQuestion}"
                        AutomationProperties.Name="Run your question" />
              </Grid>

              <TextBlock Text="OR TRY"
                         Style="{StaticResource AtlasMonoCaption}"
                         Foreground="{StaticResource AtlasTextMutedBrush}" />
              <!-- Chips are a projection of the loaded model (SuggestionEngine). The bound
                   Suggestion reaches RunSuggestion through utu:CommandExtensions.Command on the
                   repeater — same item-as-parameter pattern proven by SelectNode on the canvas. -->
              <mvux:FeedView Source="{Binding Suggestions}">
                <mvux:FeedView.ValueTemplate>
                  <DataTemplate>
                    <ItemsRepeater ItemsSource="{Binding Data}"
                                   utu:CommandExtensions.Command="{Binding Parent.RunSuggestion}">
                      <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="6" />
                      </ItemsRepeater.Layout>
                      <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <Button Style="{StaticResource AtlasQueryButtonStyle}"
                                  AutomationProperties.Name="{Binding Spoken}">
                            <utu:AutoLayout Orientation="Horizontal" Justify="SpaceBetween" CounterAxisAlignment="Center">
                              <utu:AutoLayout Orientation="Horizontal" Spacing="10" CounterAxisAlignment="Center">
                                <TextBlock Text="{Binding Verb}" Style="{StaticResource AtlasMonoCaption}" Foreground="{StaticResource AtlasLiveBrush}" />
                                <TextBlock Text="{Binding Label}" Style="{StaticResource AtlasUiBody}" />
                              </utu:AutoLayout>
                              <!-- Count badge: shown only for pre-run smell chips (Count != null) -->
                              <Border CornerRadius="999"
                                      BorderBrush="{StaticResource AtlasBorder2Brush}"
                                      BorderThickness="1"
                                      Padding="7,2"
                                      Visibility="{Binding Count, Converter={StaticResource NotNullVisible}}">
                                <TextBlock Text="{Binding Count}"
                                           Style="{StaticResource AtlasMonoCaption}"
                                           Foreground="{StaticResource AtlasTextMutedBrush}" />
                              </Border>
                            </utu:AutoLayout>
                          </Button>
                        </DataTemplate>
                      </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                  </DataTemplate>
                </mvux:FeedView.ValueTemplate>
                <mvux:FeedView.NoneTemplate>
                  <DataTemplate>
                    <TextBlock Text="No structural suggestions for this model."
                               Style="{StaticResource AtlasUiMuted}" />
                  </DataTemplate>
                </mvux:FeedView.NoneTemplate>
              </mvux:FeedView>
              <mvux:FeedView Source="{Binding AgentResult}">
                <mvux:FeedView.ValueTemplate>
                  <DataTemplate>
                    <utu:AutoLayout Orientation="Vertical"
                                    Spacing="10"
                                    Padding="0,4,6,0"
                                    BorderBrush="{StaticResource AtlasBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Loaded="Reveal_Loaded">
                      <TextBlock Text="AGENT"
                                 Margin="0,12,0,0"
                                 Style="{StaticResource AtlasMonoCaption}" />
                      <TextBlock Text="{Binding Data.Answer}"
                                 Style="{StaticResource AtlasUiProse}" />
                      <Button Content="Clear highlights"
                              Style="{StaticResource TextButtonStyle}"
                              Command="{Binding Parent.ClearHighlights}"
                              AutomationProperties.Name="Clear highlights" />
                    </utu:AutoLayout>
                  </DataTemplate>
                </mvux:FeedView.ValueTemplate>
                <mvux:FeedView.NoneTemplate>
                  <DataTemplate>
                    <Grid />
                  </DataTemplate>
                </mvux:FeedView.NoneTemplate>
              </mvux:FeedView>
            </utu:AutoLayout>
          </ScrollViewer>

          <!-- Inspector pane: IDE-minimal — glyph + name + route breadcrumb, a hairline
               provenance spine, collapsible sections over a properties grid, sticky commands. -->
          <Grid Grid.Row="1"
                Visibility="{Binding SelectedIndex, ElementName=PanelTabs, Converter={StaticResource IndexVisible}, ConverterParameter=1}">
            <Grid.RowDefinitions>
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0">
              <utu:AutoLayout Orientation="Vertical" Spacing="0">
                <mvux:FeedView Source="{Binding Selected}">
                  <mvux:FeedView.ValueTemplate>
                    <DataTemplate>
                      <utu:AutoLayout Orientation="Vertical" Spacing="0">

                        <!-- node header: tree glyph + name + route breadcrumb + status -->
                        <Grid Padding="16,16,16,12" ColumnSpacing="10">
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                          </Grid.ColumnDefinitions>
                          <Border Width="18" Height="18" CornerRadius="3" VerticalAlignment="Top"
                                  Background="{StaticResource AtlasSurfaceBrush}"
                                  BorderBrush="{StaticResource AtlasBorder2Brush}" BorderThickness="1">
                            <Path Data="M 4,2 L 11,2 L 11,13 L 4,13 Z M 6,5.5 L 9,5.5 M 6,8 L 9,8"
                                  Stroke="{StaticResource AtlasDeclaredBrush}" StrokeThickness="1"
                                  HorizontalAlignment="Center" VerticalAlignment="Center" />
                          </Border>
                          <utu:AutoLayout Grid.Column="1" Orientation="Vertical" Spacing="4">
                            <TextBlock Text="{Binding Data.Name}" Style="{StaticResource AtlasUiName}" />
                            <TextBlock Text="{Binding Data.Route}" Style="{StaticResource AtlasMonoRoute}" TextTrimming="CharacterEllipsis" />
                          </utu:AutoLayout>
                          <utu:AutoLayout Grid.Column="2" Orientation="Horizontal" Spacing="6">
                            <Border CornerRadius="3" Padding="7,2" Background="{StaticResource AtlasLiveBrush}"
                                    Visibility="{Binding Data.Status, Converter={StaticResource StatusVisible}, ConverterParameter=Live}">
                              <TextBlock Text="LIVE" Style="{StaticResource AtlasMonoCaption}" Foreground="{StaticResource AtlasOnAccentBrush}" />
                            </Border>
                            <Border CornerRadius="3" Padding="7,2" Background="{StaticResource AtlasOrphanBrush}"
                                    Visibility="{Binding Data.Status, Converter={StaticResource StatusVisible}, ConverterParameter=Orphan}">
                              <TextBlock Text="ORPHAN" Style="{StaticResource AtlasMonoCaption}" Foreground="{StaticResource AtlasOnCoralBrush}" />
                            </Border>
                          </utu:AutoLayout>
                        </Grid>

                        <!-- body: provenance spine + collapsible sections -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2" />
                            <ColumnDefinition Width="*" />
                          </Grid.ColumnDefinitions>
                          <Rectangle Fill="{StaticResource AtlasLiveDimBrush}" />

                          <utu:AutoLayout Grid.Column="1" Orientation="Vertical" Spacing="0">

                            <controls:InspectorSection Header="SOURCE" Style="{StaticResource InspectorSectionStyle}">
                              <Grid ColumnSpacing="12" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="84" />
                                  <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                  <RowDefinition Height="Auto" />
                                  <RowDefinition Height="Auto" />
                                  <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Kind" Style="{StaticResource AtlasUiKey}" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Data.Kind}" Style="{StaticResource AtlasMonoBody}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="View" Style="{StaticResource AtlasUiKey}" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Data.View}" Style="{StaticResource AtlasMonoBody}" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="View-model" Style="{StaticResource AtlasUiKey}" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Data.ViewModel}" Style="{StaticResource AtlasMonoType}" />
                              </Grid>
                            </controls:InspectorSection>

                            <controls:InspectorSection Header="FILES" Count="{Binding Data.Files.Count}" Style="{StaticResource InspectorSectionStyle}">
                              <ItemsRepeater ItemsSource="{Binding Data.Files}">
                                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="3" /></ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource AtlasMonoMuted}" />
                                  </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                              </ItemsRepeater>
                            </controls:InspectorSection>

                            <controls:InspectorSection Header="ELEMENTS" Count="{Binding Data.Elements.Count}" Style="{StaticResource InspectorSectionStyle}">
                              <ItemsRepeater ItemsSource="{Binding Data.Elements}">
                                <ItemsRepeater.Layout><StackLayout Orientation="Vertical" Spacing="3" /></ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                  <DataTemplate>
                                    <TextBlock Text="{Binding}" Style="{StaticResource AtlasMonoMuted}" />
                                  </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                              </ItemsRepeater>
                            </controls:InspectorSection>

                            <controls:InspectorSection Header="THEME TOKENS" Count="{Binding Data.Tokens.Count}" Style="{StaticResource InspectorSectionStyle}">
                              <ItemsRepeater ItemsSource="{Binding Data.Tokens}">
                                <ItemsRepeater.Layout><StackLayout Orientation="Horizontal" Spacing="5" /></ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                  <DataTemplate>
                                    <Border BorderBrush="{StaticResource AtlasBorder2Brush}" BorderThickness="1" CornerRadius="4" Padding="7,2">
                                      <TextBlock Text="{Binding}" Style="{StaticResource AtlasMonoCaption}" Foreground="{StaticResource AtlasShellBrush}" />
                                    </Border>
                                  </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                              </ItemsRepeater>
                            </controls:InspectorSection>

                            <controls:InspectorSection Header="MODEL · AS THE AGENT SEES IT" IsOpen="False" Style="{StaticResource InspectorSectionStyle}">
                              <Border Background="{StaticResource AtlasSurfaceBrush}" BorderBrush="{StaticResource AtlasBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="11">
                                <TextBlock Text="{Binding Data, Converter={StaticResource NodeJson}}" Style="{StaticResource AtlasMonoMuted}" TextWrapping="Wrap" />
                              </Border>
                            </controls:InspectorSection>

                          </utu:AutoLayout>
                        </Grid>
                      </utu:AutoLayout>
                    </DataTemplate>
                  </mvux:FeedView.ValueTemplate>
                  <mvux:FeedView.NoneTemplate>
                    <DataTemplate>
                      <TextBlock Padding="16,20"
                                 Text="Select a node on the canvas to inspect its view, view-model, route, and the model the agent receives."
                                 Style="{StaticResource AtlasUiMuted}" />
                    </DataTemplate>
                  </mvux:FeedView.NoneTemplate>
                </mvux:FeedView>

                <!-- Scoped edit context (gated on the projected string being present) -->
                <utu:AutoLayout Orientation="Vertical" Spacing="7" Padding="16,12,16,16"
                                BorderBrush="{StaticResource AtlasBorderBrush}" BorderThickness="0,1,0,0"
                                Opacity="0" Visibility="Collapsed"
                                local:Reveal.When="{Binding ScopedContext}">
                  <TextBlock Text="SCOPED EDIT CONTEXT" Style="{StaticResource AtlasMonoCaption}" />
                  <Border Background="{StaticResource AtlasSurfaceBrush}" BorderBrush="{StaticResource AtlasLiveDimBrush}" BorderThickness="1" CornerRadius="4" Padding="11">
                    <TextBlock x:Name="ScopedContextText" Text="{Binding ScopedContext}" Style="{StaticResource AtlasMonoMuted}" TextWrapping="Wrap" />
                  </Border>
                  <utu:AutoLayout Orientation="Horizontal" Spacing="8">
                    <Button Content="Copy context" Style="{StaticResource TextButtonStyle}" Click="CopyContext_Click" AutomationProperties.Name="Copy scoped edit context to clipboard" />
                    <Button Content="Clear context" Style="{StaticResource TextButtonStyle}" Command="{Binding ClearScope}" AutomationProperties.Name="Clear scoped edit context" />
                  </utu:AutoLayout>
                </utu:AutoLayout>
              </utu:AutoLayout>
            </ScrollViewer>

            <!-- sticky command bar, shown only with a selection -->
            <Border Grid.Row="1"
                    Background="{StaticResource AtlasPanelBrush}"
                    BorderBrush="{StaticResource AtlasBorderBrush}" BorderThickness="0,1,0,0"
                    Padding="16,12"
                    Visibility="{Binding Selected.Id, Converter={StaticResource StringVisible}}">
              <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Jump to live" HorizontalAlignment="Stretch"
                        Style="{StaticResource OutlinedButtonStyle}" Command="{Binding JumpTo}"
                        IsEnabled="{Binding RuntimeConnected}"
                        AutomationProperties.Name="Jump to this screen in the running app" />
                <Button Grid.Column="1" Content="Scope edit" HorizontalAlignment="Stretch"
                        Style="{StaticResource FilledButtonStyle}" Command="{Binding ScopeEdit}"
                        AutomationProperties.Name="Scope an agent edit for this screen" />
              </Grid>
            </Border>
          </Grid>
      </Grid>
    </Grid>
  </Grid>
</Page>
