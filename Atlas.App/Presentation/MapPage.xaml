<Page x:Class="Atlas.App.Presentation.MapPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Atlas.App.Presentation"
      xmlns:controls="using:Atlas.App.Presentation.Controls"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      NavigationCacheMode="Required"
      Background="{StaticResource AtlasCanvasBrush}">

  <Page.Resources>
    <local:UpperConverter x:Key="Upper" />
    <local:StatusVisibleConverter x:Key="StatusVisible" />
    <local:NodeJsonConverter x:Key="NodeJson" />
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Top bar -->
    <utu:AutoLayout Orientation="Horizontal"
                    Justify="SpaceBetween"
                    CounterAxisAlignment="Center"
                    Spacing="18"
                    Padding="18,10"
                    Background="{StaticResource AtlasPanelBrush}"
                    BorderBrush="{StaticResource AtlasBorderBrush}"
                    BorderThickness="0,0,0,1">

      <utu:AutoLayout Orientation="Horizontal"
                      Spacing="10"
                      CounterAxisAlignment="Center">
        <!-- Sized wrapper: the 45° rotation otherwise overflows the layout slot -->
        <Grid Width="22"
              Height="22">
          <Border Width="14"
                  Height="14"
                  CornerRadius="3"
                  RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
              <RotateTransform Angle="45" />
            </Border.RenderTransform>
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{StaticResource AtlasUnreachableColor}" Offset="0" />
                <GradientStop Color="{StaticResource AtlasDeclaredColor}" Offset="0.33" />
                <GradientStop Color="{StaticResource AtlasObservedColor}" Offset="0.66" />
                <GradientStop Color="{StaticResource AtlasShellColor}" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </Grid>
        <TextBlock Text="ATLAS"
                   Style="{StaticResource AtlasMonoTitle}"
                   CharacterSpacing="140" />
        <TextBlock Text="AGENTIC APP MAP"
                   Style="{StaticResource AtlasMonoCaption}" />
      </utu:AutoLayout>

      <utu:AutoLayout Orientation="Horizontal"
                      Spacing="8"
                      CounterAxisAlignment="Center">
        <Border CornerRadius="999"
                Padding="11,5"
                BorderBrush="{StaticResource AtlasBorderBrush}"
                BorderThickness="1">
          <TextBlock x:Name="AppNamePill"
                     Text="ROUNDSAPP.MOBILE"
                     Style="{StaticResource AtlasMonoCaption}"
                     Foreground="{StaticResource AtlasTextBrush}" />
        </Border>
        <Border CornerRadius="999"
                Padding="11,5"
                BorderBrush="{StaticResource AtlasBorderBrush}"
                BorderThickness="1">
          <TextBlock Text="STATIC · SAMPLE MODEL"
                     Style="{StaticResource AtlasMonoCaption}" />
        </Border>
      </utu:AutoLayout>
    </utu:AutoLayout>

    <!-- Content: canvas + docked panel. The panel is a fixed column on wide form factors
         (SPEC); DrawerControl is reserved for narrow widths — while open it covers the
         main content with a hit-test-visible light-dismiss overlay that blocks the canvas. -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="372" />
      </Grid.ColumnDefinitions>

      <Grid Background="{StaticResource AtlasCanvasBrush}">
          <utu:ZoomContentControl x:Name="MapZoom"
                                  MinZoomLevel="0.25"
                                  MaxZoomLevel="3.0"
                                  IsZoomAllowed="True"
                                  IsPanAllowed="True"
                                  HorizontalContentAlignment="Stretch"
                                  VerticalContentAlignment="Stretch">
            <mvux:FeedView Source="{Binding Graph}">
              <mvux:FeedView.ValueTemplate>
                <DataTemplate>
                  <Canvas Width="1700"
                          Height="660">
                    <!-- StaticResource: ThemeResource does not apply to custom DPs inside templates -->
                    <controls:EdgeLayer Source="{Binding Data}"
                                        ObservedBrush="{StaticResource AtlasObservedBrush}"
                                        DeclaredBrush="{StaticResource AtlasDeclaredBrush}"
                                        UnreachableBrush="{StaticResource AtlasUnreachableBrush}"
                                        ShowObserved="{Binding DataContext.ShowObserved, ElementName=Root, Mode=OneWay}"
                                        ShowDeclared="{Binding DataContext.ShowDeclared, ElementName=Root, Mode=OneWay}"
                                        ShowUnreachable="{Binding DataContext.ShowUnreachable, ElementName=Root, Mode=OneWay}" />
                    <!-- Parent = the page VM exposed by FeedView's template state -->
                    <ItemsRepeater ItemsSource="{Binding Data.Nodes}"
                                   utu:CommandExtensions.Command="{Binding Parent.SelectNode}">
                      <ItemsRepeater.Layout>
                        <local:CanvasLayout />
                      </ItemsRepeater.Layout>
                      <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <controls:NodeCard SelectedId="{Binding DataContext.Selected.Id, ElementName=Root, Mode=OneWay}" />
                        </DataTemplate>
                      </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                  </Canvas>
                </DataTemplate>
              </mvux:FeedView.ValueTemplate>
            </mvux:FeedView>
          </utu:ZoomContentControl>

          <!-- Legend: provenance layer toggles (line style + color per kind) -->
          <Border HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="14"
                  Background="{StaticResource AtlasPanelBrush}"
                  BorderBrush="{StaticResource AtlasBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="9"
                  Padding="13,11">
            <utu:AutoLayout Orientation="Vertical"
                            Spacing="4">
              <CheckBox IsChecked="{Binding ShowObserved, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle observed edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasObservedBrush}"
                        StrokeThickness="2" />
                  <TextBlock Text="Observed"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="RUNTIME"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <CheckBox IsChecked="{Binding ShowDeclared, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle declared edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasDeclaredBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="3,3" />
                  <TextBlock Text="Declared"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="ROUTE MAP"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <CheckBox IsChecked="{Binding ShowUnreachable, Mode=TwoWay}"
                        MinWidth="0"
                        AutomationProperties.Name="Toggle unreachable edges">
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="9"
                                CounterAxisAlignment="Center">
                  <Line X2="22"
                        Stroke="{StaticResource AtlasUnreachableBrush}"
                        StrokeThickness="2"
                        StrokeDashArray="1,3" />
                  <TextBlock Text="Unreachable"
                             Style="{StaticResource AtlasMonoMuted}" />
                  <TextBlock Text="DEAD"
                             Style="{StaticResource AtlasMonoCaption}" />
                </utu:AutoLayout>
              </CheckBox>
              <TextBlock Text="TOGGLE LAYERS"
                         Style="{StaticResource AtlasMonoCaption}" />
            </utu:AutoLayout>
          </Border>

          <!-- View controls -->
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="7"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Bottom"
                          Margin="0,0,14,14">
            <Button x:Name="ZoomOutButton"
                    Content="−"
                    Click="ZoomOut_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Zoom out" />
            <Button x:Name="ZoomInButton"
                    Content="+"
                    Click="ZoomIn_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Zoom in" />
            <Button x:Name="ZoomFitButton"
                    Content="⊡"
                    Click="ZoomFit_Click"
                    Style="{StaticResource OutlinedButtonStyle}"
                    MinWidth="44"
                    MinHeight="44"
                    Padding="0"
                    AutomationProperties.Name="Fit map to view" />
          </utu:AutoLayout>
      </Grid>

      <!-- Docked panel -->
      <Grid Grid.Column="1"
            Background="{StaticResource AtlasPanelBrush}"
            BorderBrush="{StaticResource AtlasBorderBrush}"
            BorderThickness="1,0,0,0">
          <ScrollViewer>
            <utu:AutoLayout Orientation="Vertical"
                            Spacing="16"
                            Padding="18">
              <TextBlock Text="INSPECTOR"
                         Style="{StaticResource AtlasMonoCaption}" />
              <mvux:FeedView Source="{Binding Selected}">
                <mvux:FeedView.ValueTemplate>
                  <DataTemplate>
                    <utu:AutoLayout Orientation="Vertical"
                                    Spacing="16">
                      <utu:AutoLayout Orientation="Horizontal"
                                      Justify="SpaceBetween"
                                      CounterAxisAlignment="Start"
                                      Spacing="10">
                        <utu:AutoLayout Orientation="Vertical"
                                        Spacing="3">
                          <TextBlock Text="{Binding Data.Name}"
                                     Style="{StaticResource AtlasMonoTitle}" />
                          <TextBlock Text="{Binding Data.Kind, Converter={StaticResource Upper}}"
                                     Style="{StaticResource AtlasMonoCaption}" />
                        </utu:AutoLayout>
                        <utu:AutoLayout Orientation="Horizontal"
                                        Spacing="6">
                          <Border CornerRadius="5"
                                  Padding="8,3"
                                  Background="{StaticResource AtlasLiveBrush}"
                                  Visibility="{Binding Data.Status, Converter={StaticResource StatusVisible}, ConverterParameter=Live}">
                            <TextBlock Text="LIVE"
                                       Style="{StaticResource AtlasMonoCaption}"
                                       Foreground="{StaticResource AtlasOnAccentBrush}" />
                          </Border>
                          <Border CornerRadius="5"
                                  Padding="8,3"
                                  Background="{StaticResource AtlasOrphanBrush}"
                                  Visibility="{Binding Data.Status, Converter={StaticResource StatusVisible}, ConverterParameter=Orphan}">
                            <TextBlock Text="ORPHAN"
                                       Style="{StaticResource AtlasMonoCaption}"
                                       Foreground="{StaticResource AtlasOnCoralBrush}" />
                          </Border>
                        </utu:AutoLayout>
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="ROUTE"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <TextBlock Style="{StaticResource AtlasMonoRoute}">
                          <Run Text="/" /><Run Text="{Binding Data.Route}" />
                        </TextBlock>
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="VIEW"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <TextBlock Text="{Binding Data.View}"
                                   Style="{StaticResource AtlasMonoBody}" />
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="VIEW-MODEL"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <TextBlock Text="{Binding Data.ViewModel}"
                                   Style="{StaticResource AtlasMonoType}" />
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="FILES"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <ItemsRepeater ItemsSource="{Binding Data.Files}">
                          <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical"
                                         Spacing="4" />
                          </ItemsRepeater.Layout>
                          <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding}"
                                         Style="{StaticResource AtlasMonoMuted}" />
                            </DataTemplate>
                          </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="ELEMENTS"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <ItemsRepeater ItemsSource="{Binding Data.Elements}">
                          <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical"
                                         Spacing="4" />
                          </ItemsRepeater.Layout>
                          <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Text="{Binding}"
                                         Style="{StaticResource AtlasMonoMuted}" />
                            </DataTemplate>
                          </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="5">
                        <TextBlock Text="THEME TOKENS"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <ItemsRepeater ItemsSource="{Binding Data.Tokens}">
                          <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal"
                                         Spacing="5" />
                          </ItemsRepeater.Layout>
                          <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                              <Border BorderBrush="{StaticResource AtlasBorderBrush}"
                                      BorderThickness="1"
                                      CornerRadius="4"
                                      Padding="6,2">
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource AtlasMonoCaption}"
                                           Foreground="{StaticResource AtlasShellBrush}" />
                              </Border>
                            </DataTemplate>
                          </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                      </utu:AutoLayout>

                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="7">
                        <TextBlock Text="MODEL · AS THE AGENT SEES IT"
                                   Style="{StaticResource AtlasMonoCaption}" />
                        <Border Background="{StaticResource AtlasSurfaceBrush}"
                                BorderBrush="{StaticResource AtlasBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                          <TextBlock Text="{Binding Data, Converter={StaticResource NodeJson}}"
                                     Style="{StaticResource AtlasMonoCaption}"
                                     Foreground="{StaticResource AtlasTextMutedBrush}"
                                     TextWrapping="Wrap" />
                        </Border>
                      </utu:AutoLayout>
                    </utu:AutoLayout>
                  </DataTemplate>
                </mvux:FeedView.ValueTemplate>
                <mvux:FeedView.NoneTemplate>
                  <DataTemplate>
                    <TextBlock Text="Select a node on the canvas to inspect its view, view-model, route, and the model the agent receives."
                               Style="{StaticResource AtlasSerifProse}"
                               Foreground="{StaticResource AtlasTextMutedBrush}" />
                  </DataTemplate>
                </mvux:FeedView.NoneTemplate>
              </mvux:FeedView>
            </utu:AutoLayout>
          </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Page>
