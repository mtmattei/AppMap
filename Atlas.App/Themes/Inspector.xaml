<!-- IDE-minimal inspector pieces: collapsible section + query-list button. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Atlas.App.Presentation.Controls">

  <Style x:Key="InspectorSectionStyle" TargetType="controls:InspectorSection">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:InspectorSection">
          <StackPanel BorderBrush="{StaticResource AtlasBorderBrush}"
                      BorderThickness="0,1,0,0">
            <Grid x:Name="PART_Header"
                  Background="Transparent"
                  Padding="16,10"
                  ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid x:Name="PART_Caret"
                    Width="8"
                    Height="8"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                  <RotateTransform Angle="90" />
                </Grid.RenderTransform>
                <Path Data="M 2,1 L 6,4 L 2,7"
                      Stroke="{StaticResource AtlasTextMuted2Brush}"
                      StrokeThickness="1.4"
                      StrokeLineJoin="Round" />
              </Grid>
              <TextBlock Grid.Column="1"
                         Text="{TemplateBinding Header}"
                         VerticalAlignment="Center"
                         Style="{StaticResource AtlasMonoCaption}" />
              <TextBlock Grid.Column="2"
                         Text="{TemplateBinding Count}"
                         VerticalAlignment="Center"
                         Style="{StaticResource AtlasMonoCaption}" />
            </Grid>
            <ContentPresenter x:Name="PART_Body"
                              Content="{TemplateBinding Content}"
                              Padding="16,2,16,12"
                              HorizontalContentAlignment="Stretch" />
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Left-aligned query row: mono verb + sans label, hairline well -->
  <Style x:Key="AtlasQueryButtonStyle" TargetType="Button">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Background" Value="{StaticResource AtlasSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource AtlasBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Content="{TemplateBinding Content}" />
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal" />
                <VisualState x:Name="PointerOver">
                  <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                      <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AtlasSurface2Brush}" />
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                      <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AtlasBorder2Brush}" />
                    </ObjectAnimationUsingKeyFrames>
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="Background">
                      <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource AtlasSurface2Brush}" />
                    </ObjectAnimationUsingKeyFrames>
                  </Storyboard>
                </VisualState>
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
