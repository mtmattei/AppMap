<!-- IDE-minimal inspector pieces: collapsible section + query-list button. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="using:Atlas.App.Presentation.Controls">

  <Style x:Key="InspectorSectionStyle" TargetType="controls:InspectorSection">
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="controls:InspectorSection">
          <StackPanel BorderBrush="{StaticResource AtlasBorderBrush}"
                      BorderThickness="0,1,0,0">
            <Grid x:Name="PART_Header"
                  Background="Transparent"
                  Padding="16,10"
                  ColumnSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Grid x:Name="PART_Caret"
                    Width="8"
                    Height="8"
                    VerticalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                  <RotateTransform Angle="90" />
                </Grid.RenderTransform>
                <Path Data="M 2,1 L 6,4 L 2,7"
                      Stroke="{StaticResource AtlasTextMuted2Brush}"
                      StrokeThickness="1.4"
                      StrokeLineJoin="Round" />
              </Grid>
              <TextBlock Grid.Column="1"
                         Text="{TemplateBinding Header}"
                         VerticalAlignment="Center"
                         Style="{StaticResource AtlasMonoCaption}" />
              <TextBlock Grid.Column="2"
                         Text="{TemplateBinding Count}"
                         VerticalAlignment="Center"
                         Style="{StaticResource AtlasMonoCaption}" />
            </Grid>
            <ContentPresenter x:Name="PART_Body"
                              Content="{TemplateBinding Content}"
                              Padding="16,2,16,12"
                              HorizontalContentAlignment="Stretch" />
          </StackPanel>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Left-aligned query row: mono verb + sans label, hairline well -->
  <Style x:Key="AtlasQueryButtonStyle" TargetType="Button">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Background" Value="{StaticResource AtlasSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource AtlasBorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="UseSystemFocusVisuals" Value="False" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <!-- Hover/press tint is a separate layer so brush changes can fade rather than snap. -->
          <Grid x:Name="Root">
            <Border x:Name="Base"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}" />
            <Border x:Name="HoverTint"
                    Background="{StaticResource AtlasSurface2Brush}"
                    BorderBrush="{StaticResource AtlasBorder2Brush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <Border x:Name="FocusRing"
                    BorderBrush="{StaticResource AtlasDeclaredBrush}"
                    BorderThickness="1"
                    CornerRadius="{TemplateBinding CornerRadius}"
                    Opacity="0" />
            <ContentPresenter Padding="{TemplateBinding Padding}"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Content="{TemplateBinding Content}" />
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CommonStates">
                <VisualState x:Name="Normal">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.15" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="PointerOver">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.12" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Pressed">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="HoverTint" Storyboard.TargetProperty="Opacity"
                                     To="0.55" Duration="0:0:0.05" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Disabled">
                  <VisualState.Setters>
                    <Setter Target="Root.Opacity" Value="0.45" />
                  </VisualState.Setters>
                </VisualState>
              </VisualStateGroup>
              <VisualStateGroup x:Name="FocusStates">
                <VisualState x:Name="Focused">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity"
                                     To="1" Duration="0:0:0.1" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="Unfocused">
                  <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="FocusRing" Storyboard.TargetProperty="Opacity"
                                     To="0" Duration="0:0:0.1" />
                  </Storyboard>
                </VisualState>
                <VisualState x:Name="PointerFocused" />
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>
