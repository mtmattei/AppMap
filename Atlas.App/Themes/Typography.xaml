<!-- Atlas type ramp: mono for chrome (labels, routes, code), serif for agent prose.
     Font families are resources so the brand fonts (Martian Mono / Newsreader) can be
     swapped in as assets without touching styles. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <FontFamily x:Key="AtlasMonoFontFamily">Cascadia Mono</FontFamily>
  <FontFamily x:Key="AtlasSerifFontFamily">Georgia</FontFamily>

  <!-- Small uppercase chrome labels: node kind, field keys, pane headers -->
  <Style x:Key="AtlasMonoCaption" TargetType="TextBlock" BasedOn="{StaticResource LabelSmall}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasMonoFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasTextMuted2Brush}" />
    <Setter Property="CharacterSpacing" Value="100" />
  </Style>

  <!-- Default chrome text -->
  <Style x:Key="AtlasMonoBody" TargetType="TextBlock" BasedOn="{StaticResource BodyMedium}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasMonoFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasTextBrush}" />
  </Style>

  <!-- Muted chrome text: secondary values, hints -->
  <Style x:Key="AtlasMonoMuted" TargetType="TextBlock" BasedOn="{StaticResource BodySmall}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasMonoFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasTextMutedBrush}" />
  </Style>

  <!-- Node and panel titles -->
  <Style x:Key="AtlasMonoTitle" TargetType="TextBlock" BasedOn="{StaticResource TitleMedium}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasMonoFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasTextBrush}" />
  </Style>

  <!-- Route paths: always sage, mirroring syntax-string color -->
  <Style x:Key="AtlasMonoRoute" TargetType="TextBlock" BasedOn="{StaticResource LabelMedium}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasMonoFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasObservedBrush}" />
  </Style>

  <!-- Agent reasoning prose -->
  <Style x:Key="AtlasSerifProse" TargetType="TextBlock" BasedOn="{StaticResource BodyLarge}">
    <Setter Property="FontFamily" Value="{StaticResource AtlasSerifFontFamily}" />
    <Setter Property="Foreground" Value="{ThemeResource AtlasTextBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="24" />
  </Style>

</ResourceDictionary>
